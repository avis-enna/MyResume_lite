{
  "name": "portfolio-website",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "analyze": "ANALYZE=true npm run build",
    "seed": "node scripts/seed-data.js",
    "test": "npm run test:setup && playwright test",
    "test:ui": "npm run test:setup && playwright test --ui",
    "test:headed": "npm run test:setup && playwright test --headed",
    "test:debug": "npm run test:setup && playwright test --debug",
    "test:setup": "npx tsx scripts/test-setup.ts setup",
    "test:cleanup": "npx tsx scripts/test-setup.ts cleanup",
    "test:admin": "npm run test:setup && playwright test tests/admin-*.spec.ts --workers=1",
    "init-admin": "npx tsx scripts/init-admin.ts",
    "admin:create": "npm run init-admin create",
    "admin:list": "npm run init-admin list",
    "admin:remove": "npm run init-admin remove",
    "admin:update-password": "npm run init-admin update-password",
    "test:comprehensive": "npx tsx scripts/comprehensive-test.ts",
    "test:stress": "npm run test:comprehensive",
    "seed:test-data": "npx tsx scripts/seed-test-data.ts",
    "test:seed": "npm run seed:test-data seed",
  "test:clear": "npm run seed:test-data clear",
  "test:bench": "npx playwright test -c playwright.bench.config.ts",
  "test:bench:run": "tsx scripts/run-test-bench.ts"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@next/bundle-analyzer": "^15.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-fetch": "^2.6.12",
    "bcryptjs": "^3.0.2",
    "critters": "^0.0.23",
    "dotenv": "^17.2.1",
    "framer-motion": "^11.11.17",
    "jose": "^6.0.12",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "mongodb": "^6.18.0",
    "mongoose": "^8.17.1",
    "next": "^15.1.0",
    "node-fetch": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "sharp": "^0.33.5",
    "tsx": "^4.20.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
